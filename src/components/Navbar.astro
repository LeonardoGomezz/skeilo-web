---
const links = [
	{ href: '#servicios', label: 'Servicios' },
	{ href: '#proceso', label: 'Proceso' },
	{ href: '#resultados', label: 'Resultados' },
	{ href: '#equipo', label: 'Equipo' },
];
---

<nav class="navbar">
	<a href="#top" class="brand">
		<img src="/favico.png" alt="" width="26" height="26" class="brand-badge" />
		<span class="brand-name">Skeilo</span>
	</a>

	<div class="nav-actions">
		<div class="nav-links">
			{links.map((link) => <a href={link.href}>{link.label}</a>)}
		</div>
		<a href="https://wa.me/573217866817" target="_blank" rel="noopener noreferrer" class="cta-button">
			Hablemos →
		</a>
	</div>
</nav>

<style>
	.navbar {
		position: sticky;
		top: 0;
		z-index: 150;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		max-width: 1280px;
		margin: 0 auto;
		padding: 16px 24px;
		backdrop-filter: blur(14px);
		-webkit-backdrop-filter: blur(14px);
		background: rgba(7, 23, 48, 0.62);
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
		color: var(--color-white);
	}

	.brand:hover {
		color: var(--color-white);
	}

	.brand-badge {
		width: 26px;
		height: 26px;
		border-radius: 7px;
		display: block;
	}

	.brand-name {
		font: 600 19px var(--font-display);
		letter-spacing: -0.01em;
	}

	.nav-actions {
		display: flex;
		align-items: center;
		gap: 20px;
		font-size: 14.5px;
	}

	.nav-links {
		display: flex;
		align-items: center;
		gap: 28px;
	}

	.nav-links a {
		color: var(--color-ink-muted);
		transition: color 0.2s;
	}

	.nav-links a:hover {
		color: var(--color-white);
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		background: var(--color-mint);
		color: var(--color-navy);
		font: 600 14px var(--font-sans);
		padding: 10px 18px;
		border-radius: 9px;
		box-shadow: 0 6px 22px rgba(0, 224, 184, 0.22);
		white-space: nowrap;
		transition: transform 0.2s;
	}

	.cta-button:hover {
		color: var(--color-navy);
		transform: translateY(-1px);
	}

	@media (max-width: 980px) {
		.nav-links {
			display: none;
		}
	}
</style>
