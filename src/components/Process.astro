---
const steps = [
	{
		step: '01',
		title: 'Descubrimiento',
		desc: 'Entendemos tu operación, tus cuellos de botella y tus objetivos de negocio.',
	},
	{
		step: '02',
		title: 'Diseño de arquitectura',
		desc: 'Definimos la solución técnica y un roadmap de entrega claro y realista.',
	},
	{
		step: '03',
		title: 'Desarrollo iterativo',
		desc: 'Construimos y entregamos en ciclos cortos, medibles y sin sorpresas.',
	},
	{
		step: '04',
		title: 'Escalamiento',
		desc: 'Optimizamos, automatizamos y acompañamos tu crecimiento a largo plazo.',
	},
];
---

<section id="proceso" class="process">
	<div class="section-inner">
		<div data-reveal class="section-head">
			<span class="eyebrow">04 — Cómo trabajamos</span>
			<h2>Un proceso claro, sin sorpresas.</h2>
			<p>
				Sabes qué esperar en cada etapa, ves avances cada dos semanas y decides sobre resultados
				reales — no promesas.
			</p>
		</div>

		<div class="process-grid">
			{
				steps.map((item) => (
					<div data-reveal class="process-step">
						<div class="process-dot" aria-hidden="true" />
						<div class="process-number">{item.step}</div>
						<h3>{item.title}</h3>
						<p>{item.desc}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.process {
		padding: 96px 24px;
		background: rgba(255, 255, 255, 0.015);
		border-top: 1px solid rgba(255, 255, 255, 0.05);
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}

	.section-inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-mint);
	}

	.section-head {
		max-width: 640px;
	}

	.section-head h2 {
		font: 600 clamp(30px, 4.5vw, 50px) / 1.04 var(--font-display);
		letter-spacing: -0.025em;
		margin: 16px 0 0;
	}

	.section-head p {
		font: 400 18px / 1.6 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 18px 0 0;
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0;
		margin: 52px 0 0;
	}

	.process-grid > :nth-child(2) {
		transition-delay: 0.06s;
	}
	.process-grid > :nth-child(3) {
		transition-delay: 0.12s;
	}
	.process-grid > :nth-child(4) {
		transition-delay: 0.18s;
	}

	.process-step {
		padding: 0 24px;
		border-left: 1px solid rgba(255, 255, 255, 0.1);
		position: relative;
	}

	.process-dot {
		position: absolute;
		left: -6px;
		top: 0;
		width: 11px;
		height: 11px;
		border-radius: 50%;
		background: var(--color-mint);
		box-shadow: 0 0 12px var(--color-mint);
	}

	.process-number {
		font: 700 15px var(--font-display);
		color: var(--color-mint);
		letter-spacing: 0.04em;
	}

	.process-step h3 {
		font: 600 21px var(--font-display);
		letter-spacing: -0.01em;
		margin: 14px 0 0;
	}

	.process-step p {
		font: 400 15px / 1.6 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 10px 0 0;
	}

	@media (max-width: 980px) {
		.process {
			padding-top: 64px;
			padding-bottom: 64px;
		}

		.process-grid {
			grid-template-columns: repeat(2, 1fr);
			row-gap: 36px;
		}
	}

	@media (max-width: 620px) {
		.process {
			padding: 48px 18px;
		}

		.process-grid {
			grid-template-columns: 1fr;
			row-gap: 32px;
		}
	}
</style>
