---
const steps = [
	{
		id: 'proc1',
		number: '01',
		color: '#00E0B8',
		title: 'Descubrimiento',
		description: 'Entendemos tu operación y tus objetivos de negocio.',
	},
	{
		id: 'proc2',
		number: '02',
		color: '#2563EB',
		title: 'Diseño de arquitectura',
		description: 'Definimos la solución técnica y el roadmap de entrega.',
	},
	{
		id: 'proc3',
		number: '03',
		color: '#2563EB',
		title: 'Desarrollo iterativo',
		description: 'Construimos y entregamos en ciclos cortos y medibles.',
	},
	{
		id: 'proc4',
		number: '04',
		color: '#0B1E3F',
		title: 'Escalamiento',
		description: 'Optimizamos, automatizamos y acompañamos el crecimiento.',
	},
];
---

<section id="proceso" class="process">
	<div class="section-inner">
		<div data-reveal="procHead" class="section-head">
			<div class="eyebrow">PROCESO</div>
			<h2>Cómo trabajamos</h2>
		</div>

		<div class="process-grid">
			{
				steps.map((step) => (
					<div data-reveal={step.id} class="process-step">
						<div class="process-number" style={`color:${step.color};border-color:${step.color}`}>
							{step.number}
						</div>
						<h3>{step.title}</h3>
						<p>{step.description}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.process {
		padding: clamp(64px, 10vw, 110px) clamp(20px, 6vw, 56px);
		background: var(--color-white);
	}

	.section-inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.12em;
		color: var(--color-blue);
		margin-bottom: 14px;
	}

	.section-head h2 {
		font: 600 clamp(28px, 4vw, 38px) / 1.15 var(--font-display);
		color: var(--color-navy);
		letter-spacing: -0.02em;
		margin: 0 0 48px;
		max-width: 600px;
	}

	.process-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 28px;
	}

	.process-step {
		transition:
			opacity 0.6s ease,
			transform 0.6s ease;
	}

	.process-grid > :nth-child(2) {
		transition-delay: 0.06s;
	}
	.process-grid > :nth-child(3) {
		transition-delay: 0.12s;
	}
	.process-grid > :nth-child(4) {
		transition-delay: 0.18s;
	}

	.process-number {
		font: 600 15px var(--font-mono);
		background: var(--color-white);
		width: 40px;
		height: 40px;
		border: 1.5px solid;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 20px;
	}

	.process-step h3 {
		font: 600 18px var(--font-display);
		color: var(--color-navy);
		margin: 0 0 10px;
	}

	.process-step p {
		font: 400 14px / 1.6 var(--font-sans);
		color: var(--color-text);
		opacity: 0.72;
		margin: 0;
	}
</style>
