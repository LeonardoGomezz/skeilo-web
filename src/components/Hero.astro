---
---

<header class="hero">
	<div class="hero-inner">
		<div class="hero-copy">
			<div class="hero-eyebrow">
				<span class="hero-dot" aria-hidden="true"></span>
				Socio tecnológico para PYMES y SaaS
			</div>
			<h1>
				Software a medida que convierte tu operación en tu <span class="grad-text"
					>ventaja competitiva</span
				>.
			</h1>
			<p>
				Diseñamos, automatizamos y escalamos el software que tu negocio necesita — con
				arquitectura cloud lista para crecer y resultados que puedes medir. Sin plantillas
				genéricas.
			</p>
			<div class="hero-cta">
				<a href="https://wa.me/573217866817" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
					<span aria-hidden="true">✆</span> Hablemos por WhatsApp
				</a>
				<a href="#resultados" class="btn btn-secondary">Ver resultados →</a>
			</div>
			<div class="hero-trust">
				<span><span class="check" aria-hidden="true">✓</span> Respuesta &lt; 24 h</span>
				<span><span class="check" aria-hidden="true">✓</span> Entregas cada 2 semanas</span>
				<span><span class="check" aria-hidden="true">✓</span> Código que es tuyo</span>
			</div>
		</div>

		<div class="hero-visual">
			<div class="hero-visual-glow" aria-hidden="true"></div>
			<div class="hero-panel">
				<div class="hero-panel-head">
					<span class="dot dot--red" aria-hidden="true"></span>
					<span class="dot dot--yellow" aria-hidden="true"></span>
					<span class="dot dot--green" aria-hidden="true"></span>
					<span class="hero-panel-label">skeilo · panel de operación</span>
				</div>
				<div class="hero-stats">
					<div class="hero-stat hero-stat--accent">
						<div class="hero-stat-label">COSTOS OPERATIVOS</div>
						<div class="hero-stat-value hero-stat-value--mint">−41%</div>
					</div>
					<div class="hero-stat">
						<div class="hero-stat-label">UPTIME</div>
						<div class="hero-stat-value">99.9%</div>
					</div>
					<div class="hero-stat hero-stat--wide">
						<div class="hero-stat-label">PROCESOS AUTOMATIZADOS</div>
						<div class="hero-bars" aria-hidden="true">
							<span style="height:32%"></span>
							<span style="height:48%"></span>
							<span style="height:40%"></span>
							<span style="height:66%"></span>
							<span class="hero-bars-blue" style="height:80%"></span>
							<span class="hero-bars-blue" style="height:100%"></span>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>

<style>
	.hero {
		position: relative;
		z-index: 1;
		max-width: 1280px;
		margin: 0 auto;
		padding: 64px 24px 96px;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: 1.05fr 0.95fr;
		gap: 56px;
		align-items: center;
	}

	.hero-copy {
		animation: fadeInUp 0.7s ease both;
	}

	.hero-eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-mint);
		display: inline-flex;
		align-items: center;
		gap: 9px;
	}

	.hero-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: var(--color-mint);
		box-shadow: 0 0 10px var(--color-mint);
	}

	.hero-copy h1 {
		font: 600 clamp(38px, 5.2vw, 66px) / 1.02 var(--font-display);
		letter-spacing: -0.03em;
		margin: 20px 0 0;
	}

	.grad-text {
		background: linear-gradient(120deg, var(--color-mint), var(--color-blue));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.hero-copy p {
		font: 400 19px / 1.6 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 24px 0 0;
		max-width: 540px;
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin: 34px 0 0;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		font: 600 16px var(--font-sans);
		padding: 16px 28px;
		border-radius: 11px;
		transition:
			transform 0.2s,
			box-shadow 0.2s,
			border-color 0.2s,
			color 0.2s;
	}

	.btn-primary {
		background: var(--color-mint);
		color: var(--color-navy);
		box-shadow: 0 10px 34px rgba(0, 224, 184, 0.28);
	}

	.btn-primary:hover {
		color: var(--color-navy);
		transform: translateY(-2px);
		box-shadow: 0 16px 44px rgba(0, 224, 184, 0.42);
	}

	.btn-secondary {
		background: rgba(255, 255, 255, 0.05);
		color: var(--color-ink);
		border: 1px solid rgba(255, 255, 255, 0.14);
	}

	.btn-secondary:hover {
		color: var(--color-white);
		border-color: rgba(0, 224, 184, 0.5);
	}

	.hero-trust {
		display: flex;
		flex-wrap: wrap;
		gap: 22px;
		margin: 38px 0 0;
		font: 400 12.5px var(--font-mono);
		color: var(--color-ink-dim);
	}

	.hero-trust span {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.check {
		color: var(--color-mint);
	}

	.hero-visual {
		position: relative;
		animation: fadeInUp 0.8s 0.1s ease both;
	}

	.hero-visual-glow {
		position: absolute;
		inset: -30px;
		background: radial-gradient(circle at 60% 40%, rgba(0, 224, 184, 0.18), transparent 70%);
		filter: blur(10px);
	}

	.hero-panel {
		position: relative;
		background: linear-gradient(160deg, var(--color-card), var(--color-navy));
		border: 1px solid rgba(120, 200, 255, 0.16);
		border-radius: 18px;
		padding: 20px;
		box-shadow: 0 30px 80px rgba(0, 0, 0, 0.5);
	}

	.hero-panel-head {
		display: flex;
		align-items: center;
		gap: 7px;
		margin-bottom: 16px;
	}

	.dot {
		width: 11px;
		height: 11px;
		border-radius: 50%;
	}

	.dot--red {
		background: #ff5f57;
	}
	.dot--yellow {
		background: #febc2e;
	}
	.dot--green {
		background: #28c840;
	}

	.hero-panel-label {
		margin-left: auto;
		font: 400 11px var(--font-mono);
		color: var(--color-ink-dim);
	}

	.hero-stats {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 12px;
	}

	.hero-stat {
		background: rgba(255, 255, 255, 0.03);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 12px;
		padding: 16px;
	}

	.hero-stat--accent {
		background: rgba(0, 224, 184, 0.08);
		border-color: rgba(0, 224, 184, 0.2);
	}

	.hero-stat--wide {
		grid-column: span 2;
		padding: 16px 16px 12px;
	}

	.hero-stat-label {
		font: 400 11px var(--font-mono);
		color: var(--color-ink-muted);
		letter-spacing: 0.06em;
	}

	.hero-stat-value {
		font: 700 30px var(--font-display);
		color: var(--color-white);
		margin-top: 6px;
	}

	.hero-stat-value--mint {
		color: var(--color-mint);
	}

	.hero-stat--wide .hero-stat-label {
		margin-bottom: 12px;
	}

	.hero-bars {
		display: flex;
		align-items: flex-end;
		gap: 6px;
		height: 56px;
	}

	.hero-bars span {
		flex: 1;
		border-radius: 4px;
		background: linear-gradient(var(--color-mint), rgba(0, 224, 184, 0.3));
	}

	.hero-bars span.hero-bars-blue {
		background: linear-gradient(var(--color-blue), rgba(37, 99, 235, 0.3));
	}

	@media (max-width: 980px) {
		.hero {
			padding: 48px 20px 56px;
		}

		.hero-inner {
			grid-template-columns: 1fr;
			gap: 40px;
		}
	}

	@media (max-width: 620px) {
		.hero {
			padding-left: 18px;
			padding-right: 18px;
		}

		.hero-stats {
			grid-template-columns: 1fr;
		}

		.hero-stat--wide {
			grid-column: span 1;
		}
	}
</style>
