---
---

<section class="hero">
	<div class="hero-blob hero-blob--top" aria-hidden="true"></div>
	<div class="hero-blob hero-blob--bottom" aria-hidden="true"></div>

	<div class="hero-inner">
		<div class="hero-copy">
			<div class="hero-eyebrow hero-fade hero-fade--1">SOCIO TECNOLÓGICO ESTRATÉGICO</div>
			<h1 class="hero-fade hero-fade--2">Transformamos desafíos en software que escala</h1>
			<p class="hero-fade hero-fade--3">
				Diseñamos y desarrollamos software a medida, combinando arquitectura cloud, automatización
				y desarrollo personalizado para generar eficiencia, reducir costos y acelerar el
				crecimiento.
			</p>
			<div class="hero-cta hero-fade hero-fade--4">
				<a href="https://wa.me/573217866817" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
					Hablemos por WhatsApp
				</a>
				<a href="#portafolio" class="btn btn-secondary">Ver portafolio</a>
			</div>
		</div>

		<div class="hero-diagram">
			<svg width="100%" height="100%" viewBox="0 0 400 280" style="overflow: visible" aria-hidden="true">
				<line x1="60" y1="220" x2="180" y2="120" stroke="rgba(255,255,255,.25)" stroke-width="1.5"></line>
				<line x1="180" y1="120" x2="320" y2="60" stroke="rgba(255,255,255,.25)" stroke-width="1.5"></line>
				<line x1="180" y1="120" x2="300" y2="200" stroke="rgba(255,255,255,.25)" stroke-width="1.5"></line>
				<line x1="60" y1="220" x2="150" y2="240" stroke="rgba(255,255,255,.25)" stroke-width="1.5"></line>
				<circle cx="60" cy="220" r="9" fill="#00E0B8"></circle>
				<circle cx="180" cy="120" r="12" fill="#2563EB"></circle>
				<circle cx="320" cy="60" r="7" fill="#fff" opacity="0.85"></circle>
				<circle cx="300" cy="200" r="9" fill="#00E0B8" opacity="0.7"></circle>
				<circle cx="150" cy="240" r="6" fill="#fff" opacity="0.6"></circle>
			</svg>
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		overflow: hidden;
		background: var(--color-navy);
		padding: clamp(64px, 12vw, 100px) clamp(20px, 6vw, 56px) clamp(80px, 12vw, 120px);
	}

	.hero-blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(40px);
		pointer-events: none;
	}

	.hero-blob--top {
		top: -10%;
		right: -5%;
		width: 60vw;
		height: 60vw;
		max-width: 800px;
		max-height: 800px;
		background: radial-gradient(circle, rgba(37, 99, 235, 0.35), transparent 60%);
		animation: drift 14s ease-in-out infinite;
	}

	.hero-blob--bottom {
		bottom: -15%;
		right: 10%;
		width: 40vw;
		height: 40vw;
		max-width: 600px;
		max-height: 600px;
		background: radial-gradient(circle, rgba(0, 224, 184, 0.22), transparent 60%);
		animation: drift 18s ease-in-out infinite reverse;
	}

	.hero-inner {
		position: relative;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 40px;
		align-items: center;
		max-width: 1280px;
		margin: 0 auto;
	}

	.hero-fade {
		opacity: 0;
		animation: fadeInUp 0.7s ease-out both;
	}

	.hero-fade--1 {
		animation-delay: 0.05s;
	}
	.hero-fade--2 {
		animation-delay: 0.15s;
	}
	.hero-fade--3 {
		animation-delay: 0.25s;
	}
	.hero-fade--4 {
		animation-delay: 0.35s;
	}

	.hero-eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.12em;
		color: var(--color-mint);
		margin-bottom: 20px;
	}

	.hero-copy h1 {
		font: 700 clamp(34px, 5.2vw, 58px) / 1.08 var(--font-display);
		color: var(--color-white);
		letter-spacing: -0.02em;
		margin: 0 0 24px;
		max-width: 560px;
	}

	.hero-copy p {
		font: 400 clamp(15px, 1.8vw, 18px) / 1.6 var(--font-sans);
		color: rgba(255, 255, 255, 0.72);
		max-width: 460px;
		margin: 0 0 36px;
	}

	.hero-cta {
		display: flex;
		gap: 16px;
		flex-wrap: wrap;
	}

	.btn {
		font: 600 14px var(--font-sans);
		padding: 16px 28px;
		border-radius: 999px;
		display: inline-block;
		transition:
			transform 0.2s,
			opacity 0.2s,
			background 0.2s;
	}

	.btn-primary {
		color: var(--color-navy);
		background: var(--color-mint);
	}

	.btn-primary:hover {
		opacity: 0.88;
		transform: translateY(-2px);
		color: var(--color-navy);
	}

	.btn-secondary {
		color: var(--color-white);
		border: 1px solid rgba(255, 255, 255, 0.3);
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
		transform: translateY(-2px);
		color: var(--color-white);
	}

	.hero-diagram {
		position: relative;
		height: 300px;
		animation: floatY 6s ease-in-out infinite alternate;
	}
</style>
