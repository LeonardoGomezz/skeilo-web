---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="brand">
		<div class="brand-bars" aria-hidden="true">
			<span></span>
			<span></span>
			<span></span>
			<span></span>
		</div>
		<span class="brand-name">Skeilo</span>
	</div>
	<span class="copyright">© {year} Skeilo. Software que escala.</span>
</footer>

<style>
	.site-footer {
		padding: 36px clamp(20px, 6vw, 56px);
		background: var(--color-navy);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		align-items: center;
		justify-content: space-between;
	}

	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
	}

	.brand-bars {
		display: flex;
		align-items: flex-end;
		gap: 2px;
		height: 15px;
	}

	.brand-bars span {
		width: 4px;
		border-radius: 1px;
	}

	.brand-bars span:nth-child(1) {
		height: 5px;
		background: var(--color-mint);
	}
	.brand-bars span:nth-child(2) {
		height: 9px;
		background: var(--color-teal);
	}
	.brand-bars span:nth-child(3) {
		height: 13px;
		background: var(--color-sky);
	}
	.brand-bars span:nth-child(4) {
		height: 15px;
		background: var(--color-blue);
	}

	.brand-name {
		font: 600 14px var(--font-display);
		color: rgba(255, 255, 255, 0.85);
	}

	.copyright {
		font: 400 13px var(--font-sans);
		color: rgba(255, 255, 255, 0.45);
	}
</style>
