---
const tech = [
	'TypeScript',
	'React',
	'Next.js',
	'Node.js',
	'Python',
	'PostgreSQL',
	'AWS',
	'Google Cloud',
	'Docker',
	'Kubernetes',
	'Astro',
	'n8n',
];
---

<section id="tecnologias" class="tecnologias">
	<div class="section-inner">
		<div data-reveal>
			<span class="eyebrow">08 — Tecnologías</span>
			<h2>Herramientas modernas, elegidas por resultado — no por moda.</h2>
			<div class="tech-list">
				{tech.map((item) => <span class="tech-pill">{item}</span>)}
			</div>
		</div>
	</div>
</section>

<style>
	.tecnologias {
		padding: 80px 24px;
		text-align: center;
		background: var(--color-navy-alt);
		border-top: 1px solid rgba(255, 255, 255, 0.07);
	}

	.section-inner {
		max-width: 1100px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-mint);
	}

	h2 {
		font: 600 clamp(26px, 3.6vw, 40px) / 1.08 var(--font-display);
		letter-spacing: -0.02em;
		margin: 14px 0 0;
	}

	.tech-list {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		justify-content: center;
		margin: 32px 0 0;
	}

	.tech-pill {
		font: 400 14px var(--font-mono);
		color: var(--color-ink-soft);
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 999px;
		padding: 10px 18px;
		transition: all 0.2s;
	}

	.tech-pill:hover {
		border-color: rgba(0, 224, 184, 0.5);
		color: var(--color-white);
	}
</style>
