---
interface Props {
	label: string;
	shape?: 'rect' | 'circle';
}

const { label, shape = 'rect' } = Astro.props;
---

<div class={`img-placeholder img-placeholder--${shape}`} role="img" aria-label={label}>
	<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<rect x="3" y="3" width="18" height="18" rx="2"></rect>
		<circle cx="8.5" cy="8.5" r="1.5"></circle>
		<path d="m21 15-5-5L5 21"></path>
	</svg>
	<span class="img-placeholder-label">{label}</span>
</div>

<style>
	.img-placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 6px;
		background: rgba(0, 0, 0, 0.04);
		border: 1.5px dashed rgba(0, 0, 0, 0.25);
		color: rgba(0, 0, 0, 0.55);
		text-align: center;
		padding: 12px;
		box-sizing: border-box;
	}

	.img-placeholder--circle {
		border-radius: 50%;
	}

	.img-placeholder svg {
		opacity: 0.45;
	}

	.img-placeholder-label {
		max-width: 90%;
		font: 500 12px system-ui, -apple-system, sans-serif;
		letter-spacing: 0.01em;
	}
</style>
