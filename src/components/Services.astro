---
const services = [
	{
		n: '01',
		icon: '⚙️',
		title: 'Desarrollo a medida',
		desc: 'Software diseñado desde cero para tu operación real, no una plantilla adaptada a la fuerza. Encaja con cómo trabaja tu empresa hoy.',
		outcome: 'Obtienes → un sistema que hace exactamente lo que necesitas.',
	},
	{
		n: '02',
		icon: '🤖',
		title: 'Automatización',
		desc: 'Eliminamos las tareas repetitivas que roban horas a tu equipo y disparan errores, conectando lo que hoy haces a mano.',
		outcome: 'Obtienes → menos costos, menos errores, más tiempo.',
	},
	{
		n: '03',
		icon: '☁️',
		title: 'Arquitectura cloud',
		desc: 'Infraestructura escalable y de alta disponibilidad, lista para soportar tu crecimiento sin reescribir todo cada año.',
		outcome: 'Obtienes → estabilidad al crecer y costos bajo control.',
	},
	{
		n: '04',
		icon: '🧭',
		title: 'Consultoría tecnológica',
		desc: 'Te ayudamos a decidir qué construir, con qué prioridad y cómo — con foco en resultados de negocio medibles.',
		outcome: 'Obtienes → una hoja de ruta clara antes de invertir.',
	},
];
---

<section id="servicios" class="services">
	<div class="section-inner">
		<div data-reveal class="section-head">
			<div class="section-head-copy">
				<span class="eyebrow">03 — Servicios</span>
				<h2>Cuatro formas de resolver tu desafío técnico.</h2>
			</div>
			<a href="https://wa.me/573217866817" target="_blank" rel="noopener noreferrer" class="head-link">
				¿No sabes cuál necesitas? Hablemos →
			</a>
		</div>

		<div class="services-grid">
			{
				services.map((service) => (
					<div data-reveal class="service-card">
						<div class="service-card-top">
							<span class="service-icon" aria-hidden="true">
								{service.icon}
							</span>
							<span class="service-n">{service.n}</span>
						</div>
						<h3>{service.title}</h3>
						<p>{service.desc}</p>
						<div class="service-outcome">{service.outcome}</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.services {
		padding: 96px 24px;
		border-top: 1px solid rgba(255, 255, 255, 0.07);
	}

	.section-inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-mint);
	}

	.section-head {
		display: flex;
		justify-content: space-between;
		align-items: flex-end;
		flex-wrap: wrap;
		gap: 20px;
	}

	.section-head-copy {
		max-width: 640px;
	}

	.section-head-copy h2 {
		font: 600 clamp(30px, 4.5vw, 50px) / 1.04 var(--font-display);
		letter-spacing: -0.025em;
		margin: 16px 0 0;
	}

	.head-link {
		color: var(--color-mint);
		font: 600 16px var(--font-sans);
		white-space: nowrap;
	}

	.head-link:hover {
		color: var(--color-mint-light);
	}

	.services-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 20px;
		margin: 44px 0 0;
	}

	.services-grid > :nth-child(2) {
		transition-delay: 0.06s;
	}
	.services-grid > :nth-child(3) {
		transition-delay: 0.12s;
	}
	.services-grid > :nth-child(4) {
		transition-delay: 0.18s;
	}

	.service-card {
		background: linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.01));
		border: 1px solid rgba(255, 255, 255, 0.09);
		border-radius: 18px;
		padding: 32px;
		display: flex;
		flex-direction: column;
		transition: border-color 0.2s;
	}

	.service-card:hover {
		border-color: rgba(0, 224, 184, 0.4);
	}

	.service-card-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}

	.service-icon {
		width: 52px;
		height: 52px;
		border-radius: 13px;
		background: rgba(0, 224, 184, 0.1);
		border: 1px solid rgba(0, 224, 184, 0.24);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-size: 24px;
	}

	.service-n {
		font: 400 12px var(--font-mono);
		color: var(--color-ink-dim);
	}

	.service-card h3 {
		font: 600 24px var(--font-display);
		letter-spacing: -0.015em;
		margin: 22px 0 0;
	}

	.service-card p {
		font: 400 15.5px / 1.6 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 12px 0 20px;
		flex: 1;
	}

	.service-outcome {
		font: 400 12.5px var(--font-mono);
		color: var(--color-mint);
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		padding-top: 16px;
	}

	@media (max-width: 980px) {
		.services {
			padding-top: 64px;
			padding-bottom: 64px;
		}

		.services-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 620px) {
		.services {
			padding: 48px 18px;
		}
	}
</style>
