---
const results = [
	{ metric: '−41%', label: 'Costos operativos' },
	{ metric: '3×', label: 'Velocidad de entrega' },
	{ metric: '99.9%', label: 'Disponibilidad (uptime)' },
	{ metric: '< 24h', label: 'Tiempo de respuesta' },
];
---

<section id="resultados" class="resultados">
	<div class="section-inner">
		<div data-reveal class="section-head">
			<span class="eyebrow">05 — Resultados</span>
			<h2>Lo que buscamos en cada proyecto.</h2>
			<p>
				Rangos objetivo basados en proyectos de software bien ejecutados. Los reemplazaremos por
				métricas reales de cliente a medida que documentamos cada caso.
			</p>
		</div>

		<div class="resultados-grid">
			{
				results.map((result) => (
					<div data-reveal class="resultado-card">
						<div class="resultado-metric">{result.metric}</div>
						<div class="resultado-label">{result.label}</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.resultados {
		padding: 96px 24px;
		background: var(--color-navy-alt);
		border-top: 1px solid rgba(255, 255, 255, 0.07);
	}

	.section-inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-mint);
	}

	.section-head {
		text-align: center;
		max-width: 720px;
		margin: 0 auto;
	}

	.section-head h2 {
		font: 600 clamp(30px, 4.5vw, 50px) / 1.04 var(--font-display);
		letter-spacing: -0.025em;
		margin: 16px 0 0;
	}

	.section-head p {
		font: 400 16px / 1.6 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 16px 0 0;
	}

	.resultados-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 20px;
		margin: 48px 0 0;
	}

	.resultados-grid > :nth-child(2) {
		transition-delay: 0.06s;
	}
	.resultados-grid > :nth-child(3) {
		transition-delay: 0.12s;
	}
	.resultados-grid > :nth-child(4) {
		transition-delay: 0.18s;
	}

	.resultado-card {
		text-align: center;
		background: linear-gradient(180deg, rgba(0, 224, 184, 0.06), rgba(255, 255, 255, 0.01));
		border: 1px solid rgba(0, 224, 184, 0.16);
		border-radius: 18px;
		padding: 34px 20px;
	}

	.resultado-metric {
		font: 700 clamp(38px, 4.5vw, 52px) var(--font-display);
		letter-spacing: -0.03em;
		background: linear-gradient(120deg, var(--color-mint), var(--color-blue));
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.resultado-label {
		color: var(--color-ink-soft);
		font-size: 15px;
		font-weight: 500;
		margin-top: 8px;
	}

	@media (max-width: 980px) {
		.resultados {
			padding-top: 64px;
			padding-bottom: 64px;
		}

		.resultados-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 620px) {
		.resultados {
			padding: 48px 18px;
		}

		.resultados-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
