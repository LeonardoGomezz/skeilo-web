---
const cases = [
	{
		sector: 'Logística',
		name: 'Plataforma de operación',
		desc: 'Centralización de procesos y trazabilidad en tiempo real para un operador en crecimiento.',
		metric: '−40% costos',
	},
	{
		sector: 'SaaS B2B',
		name: 'Motor de automatización',
		desc: 'Automatización de flujos manuales que liberó al equipo de tareas repetitivas.',
		metric: '+3× velocidad',
	},
	{
		sector: 'Retail',
		name: 'Arquitectura escalable',
		desc: 'Migración a la nube con alta disponibilidad para soportar picos de demanda.',
		metric: '99.9% uptime',
	},
];
---

<section id="portafolio" class="portfolio">
	<div class="section-inner">
		<div data-reveal class="section-head">
			<div class="section-head-copy">
				<span class="eyebrow">06 — Casos de éxito</span>
				<h2>Proyectos reales, muy pronto.</h2>
				<p>
					Estamos documentando nuestros primeros casos con métricas verificables. Aquí verás el
					sector, el reto y el resultado medible de cada uno.
				</p>
			</div>
			<span class="pill">En preparación</span>
		</div>

		<div class="cases-grid">
			{
				cases.map((item) => (
					<div data-reveal class="case-card">
						<div class="case-image">
							<span class="case-image-label">captura del proyecto</span>
						</div>
						<div class="case-body">
							<span class="case-sector">{item.sector}</span>
							<h3>{item.name}</h3>
							<p>{item.desc}</p>
							<div class="case-metric">{item.metric}</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.portfolio {
		padding: 96px 24px;
		border-top: 1px solid rgba(255, 255, 255, 0.07);
	}

	.section-inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--color-mint);
	}

	.section-head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 16px;
	}

	.section-head-copy {
		max-width: 640px;
	}

	.section-head-copy h2 {
		font: 600 clamp(30px, 4.5vw, 50px) / 1.04 var(--font-display);
		letter-spacing: -0.025em;
		margin: 16px 0 0;
	}

	.section-head-copy p {
		font: 400 17px / 1.6 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 16px 0 0;
	}

	.pill {
		font: 400 12px var(--font-mono);
		color: var(--color-blue);
		border: 1px solid rgba(37, 99, 235, 0.3);
		border-radius: 999px;
		padding: 8px 16px;
	}

	.cases-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 20px;
		margin: 44px 0 0;
	}

	.cases-grid > :nth-child(2) {
		transition-delay: 0.06s;
	}
	.cases-grid > :nth-child(3) {
		transition-delay: 0.12s;
	}

	.case-card {
		background: rgba(255, 255, 255, 0.025);
		border: 1px solid rgba(255, 255, 255, 0.08);
		border-radius: 18px;
		overflow: hidden;
		transition: border-color 0.2s;
	}

	.case-card:hover {
		border-color: rgba(0, 224, 184, 0.35);
	}

	.case-image {
		height: 180px;
		background-image: repeating-linear-gradient(
			135deg,
			rgba(0, 224, 184, 0.09) 0,
			rgba(0, 224, 184, 0.09) 2px,
			transparent 2px,
			transparent 12px
		);
		background-color: var(--color-navy);
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		border-bottom: 1px solid rgba(255, 255, 255, 0.06);
	}

	.case-image-label {
		font: 400 12px var(--font-mono);
		color: var(--color-ink-dim);
		background: rgba(7, 23, 48, 0.7);
		padding: 6px 12px;
		border-radius: 6px;
	}

	.case-body {
		padding: 24px;
	}

	.case-sector {
		font: 400 11px var(--font-mono);
		letter-spacing: 0.1em;
		color: var(--color-mint);
		text-transform: uppercase;
	}

	.case-body h3 {
		font: 600 20px var(--font-display);
		letter-spacing: -0.01em;
		margin: 10px 0 0;
	}

	.case-body p {
		font: 400 14.5px / 1.55 var(--font-sans);
		color: var(--color-ink-muted);
		margin: 8px 0 16px;
	}

	.case-metric {
		font: 700 22px var(--font-display);
		color: var(--color-mint);
	}

	@media (max-width: 980px) {
		.portfolio {
			padding-top: 64px;
			padding-bottom: 64px;
		}

		.cases-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 620px) {
		.portfolio {
			padding: 48px 18px;
		}

		.cases-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
