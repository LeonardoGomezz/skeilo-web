---
import ImagePlaceholder from './ImagePlaceholder.astro';

const projects = [
	{
		id: 'port1',
		sector: '[SECTOR / CLIENTE]',
		name: '[Nombre del proyecto]',
		result: '[Resultado medible, ej. -40% costos]',
	},
	{
		id: 'port2',
		sector: '[SECTOR / CLIENTE]',
		name: '[Nombre del proyecto]',
		result: '[Resultado medible, ej. +3x velocidad]',
	},
	{
		id: 'port3',
		sector: '[SECTOR / CLIENTE]',
		name: '[Nombre del proyecto]',
		result: '[Resultado medible, ej. 99.9% uptime]',
	},
];
---

<section id="portafolio" class="portfolio">
	<div class="section-inner">
		<div data-reveal="portHead" class="section-head">
			<div class="eyebrow">CASOS DE ÉXITO</div>
			<h2>Resultados que hablan por sí solos.</h2>
			<p>Placeholders — reemplaza con tus proyectos y métricas reales.</p>
		</div>

		<div class="portfolio-grid">
			{
				projects.map((project) => (
					<div data-reveal={project.id} class="project-card">
						<div class="project-image">
							<ImagePlaceholder label="Captura del proyecto" shape="rect" />
						</div>
						<div class="project-body">
							<div class="project-sector">{project.sector}</div>
							<h3>{project.name}</h3>
							<p class="project-result">{project.result}</p>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.portfolio {
		padding: clamp(64px, 10vw, 110px) clamp(20px, 6vw, 56px);
		background:
			radial-gradient(circle at 10% 90%, rgba(0, 224, 184, 0.12), transparent 45%),
			var(--color-navy);
	}

	.section-inner {
		max-width: 1280px;
		margin: 0 auto;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.12em;
		color: var(--color-mint);
		margin-bottom: 14px;
	}

	.section-head h2 {
		font: 600 clamp(28px, 4vw, 38px) / 1.15 var(--font-display);
		color: var(--color-white);
		letter-spacing: -0.02em;
		margin: 0 0 12px;
		max-width: 600px;
	}

	.section-head p {
		font: 400 15px / 1.6 var(--font-sans);
		color: rgba(255, 255, 255, 0.6);
		margin: 0 0 48px;
		max-width: 560px;
	}

	.portfolio-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
		gap: 24px;
	}

	.project-card {
		background: var(--color-white);
		border-radius: 14px;
		overflow: hidden;
		transition:
			box-shadow 0.25s ease,
			opacity 0.6s ease,
			transform 0.6s ease;
	}

	.project-card:hover {
		transform: translateY(-6px);
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.25);
	}

	.portfolio-grid > :nth-child(2) {
		transition-delay: 0.06s;
	}
	.portfolio-grid > :nth-child(3) {
		transition-delay: 0.12s;
	}

	.project-image {
		width: 100%;
		height: 180px;
	}

	.project-body {
		padding: 24px;
	}

	.project-sector {
		font: 500 11px var(--font-mono);
		color: var(--color-blue);
		opacity: 0.7;
		margin-bottom: 8px;
	}

	.project-body h3 {
		font: 600 18px var(--font-display);
		color: var(--color-navy);
		margin: 0 0 10px;
	}

	.project-result {
		font: 400 13px var(--font-mono);
		color: var(--color-result);
		margin: 0;
	}
</style>
