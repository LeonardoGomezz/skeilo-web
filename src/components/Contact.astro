---
import { RECAPTCHA_SITE_KEY } from 'astro:env/client';
---

<section id="contacto" class="contact">
	<div class="contact-inner">
		<div>
			<div data-reveal="contactHead" class="contact-head">
				<div class="eyebrow">CONTACTO</div>
				<h2>Hablemos de tu próximo proyecto</h2>
				<p>Cuéntanos tu desafío y te respondemos con una propuesta concreta.</p>
				<a
					href="https://wa.me/573217866817"
					target="_blank"
					rel="noopener noreferrer"
					class="contact-cta"
				>
					Escríbenos por WhatsApp
				</a>
				<div class="contact-details">
					<div>✉ skeilo.tech@gmail.com</div>
					<div>✆ +57 321 786 6817</div>
					<div>⊕ www.skeilo.tech</div>
				</div>
			</div>
		</div>

		<div data-reveal="contactForm" class="contact-form-wrap">
			<form id="contact-form" class="contact-form" novalidate>
				<div class="field">
					<label for="contact-name">Nombre</label>
					<input type="text" id="contact-name" name="name" autocomplete="name" placeholder="Tu nombre" />
				</div>
				<div class="field">
					<label for="contact-email">Correo</label>
					<input type="email" id="contact-email" name="email" autocomplete="email" placeholder="tu@empresa.com" />
				</div>
				<div class="field">
					<label for="contact-company">Empresa</label>
					<input type="text" id="contact-company" name="company" autocomplete="organization" placeholder="Nombre de tu empresa" />
				</div>
				<div class="field">
					<label for="contact-message">Mensaje</label>
					<textarea id="contact-message" name="message" rows="4" placeholder="Cuéntanos tu proyecto"></textarea>
				</div>

				<div id="form-error" class="form-message form-message--error" hidden>
					<span>⚠ <span id="form-error-text"></span></span>
				</div>
				<div id="form-success" class="form-message form-message--success" hidden>
					<span>✓ Mensaje enviado. Te responderemos pronto.</span>
				</div>

				<button type="submit" id="form-submit" class="submit-button">Enviar mensaje</button>

				<p class="recaptcha-disclaimer">
					Este sitio está protegido por reCAPTCHA y aplican la{' '}
					<a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer"
						>Política de Privacidad</a
					>{' '}
					y los{' '}
					<a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer"
						>Términos de Servicio</a
					>{' '}
					de Google.
				</p>
			</form>
		</div>
	</div>
</section>

<script is:inline src={`https://www.google.com/recaptcha/api.js?render=${RECAPTCHA_SITE_KEY}`}></script>

<style>
	.contact {
		padding: clamp(64px, 10vw, 110px) clamp(20px, 6vw, 56px);
		background:
			radial-gradient(circle at 90% 10%, rgba(37, 99, 235, 0.25), transparent 45%),
			var(--color-navy);
	}

	.contact-inner {
		max-width: 1280px;
		margin: 0 auto;
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
		gap: 56px;
		align-items: start;
	}

	.eyebrow {
		font: 500 12px var(--font-mono);
		letter-spacing: 0.12em;
		color: var(--color-mint);
		margin-bottom: 14px;
	}

	.contact-head h2 {
		font: 600 clamp(28px, 4vw, 38px) / 1.15 var(--font-display);
		color: var(--color-white);
		letter-spacing: -0.02em;
		margin: 0 0 20px;
	}

	.contact-head p {
		font: 400 16px / 1.6 var(--font-sans);
		color: rgba(255, 255, 255, 0.7);
		margin: 0 0 32px;
		max-width: 400px;
	}

	.contact-cta {
		display: inline-block;
		font: 600 14px var(--font-sans);
		color: var(--color-navy);
		background: var(--color-mint);
		padding: 16px 28px;
		border-radius: 999px;
		margin-bottom: 28px;
		transition:
			transform 0.2s,
			opacity 0.2s;
	}

	.contact-cta:hover {
		opacity: 0.88;
		transform: translateY(-2px);
		color: var(--color-navy);
	}

	.contact-details {
		display: flex;
		flex-direction: column;
		gap: 10px;
		font: 400 15px var(--font-sans);
		color: rgba(255, 255, 255, 0.75);
	}

	.contact-form-wrap {
		background: var(--color-white);
		border-radius: 16px;
		padding: clamp(28px, 4vw, 40px);
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 18px;
	}

	.field label {
		font: 500 12px var(--font-sans);
		color: var(--color-text);
		opacity: 0.6;
		display: block;
		margin-bottom: 6px;
	}

	.field input,
	.field textarea {
		width: 100%;
		box-sizing: border-box;
		border: 1px solid var(--color-bg-light);
		background: var(--color-bg-light);
		border-radius: 8px;
		padding: 12px 14px;
		font: 400 14px var(--font-sans);
		color: var(--color-text);
	}

	.field textarea {
		resize: vertical;
	}

	.form-message {
		border-radius: 8px;
		padding: 12px 14px;
		font: 500 13px var(--font-sans);
	}

	.form-message--error {
		background: var(--color-error-bg);
		border: 1px solid var(--color-error-border);
		color: var(--color-error-text);
	}

	.form-message--success {
		background: var(--color-success-bg);
		border: 1px solid var(--color-success-border);
		color: var(--color-success-text);
	}

	.submit-button {
		font: 600 14px var(--font-sans);
		color: var(--color-white);
		background: var(--color-navy);
		padding: 14px 28px;
		border: none;
		border-radius: 8px;
		cursor: pointer;
		transition:
			background 0.2s,
			transform 0.2s;
	}

	.submit-button:hover:not(:disabled) {
		background: var(--color-navy-hover);
		transform: translateY(-2px);
	}

	.submit-button:disabled {
		cursor: not-allowed;
	}

	.recaptcha-disclaimer {
		font: 400 12px / 1.5 var(--font-sans);
		color: var(--color-text);
		opacity: 0.55;
		margin: -6px 0 0;
	}

	.recaptcha-disclaimer a {
		color: var(--color-blue);
	}
</style>

<script>
	import { RECAPTCHA_SITE_KEY } from 'astro:env/client';

	declare global {
		interface Window {
			grecaptcha?: {
				ready: (callback: () => void) => void;
				execute: (siteKey: string, options: { action: string }) => Promise<string>;
			};
		}
	}

	const getRecaptchaToken = (): Promise<string> =>
		new Promise((resolve, reject) => {
			if (!window.grecaptcha) {
				reject(new Error('reCAPTCHA no está disponible.'));
				return;
			}

			window.grecaptcha.ready(() => {
				window
					.grecaptcha!.execute(RECAPTCHA_SITE_KEY, { action: 'contact' })
					.then(resolve)
					.catch(reject);
			});
		});

	const form = document.getElementById('contact-form') as HTMLFormElement | null;
	const submitButton = document.getElementById('form-submit') as HTMLButtonElement | null;
	const errorBox = document.getElementById('form-error');
	const errorText = document.getElementById('form-error-text');
	const successBox = document.getElementById('form-success');

	if (form && submitButton && errorBox && errorText && successBox) {
		const nameInput = form.elements.namedItem('name') as HTMLInputElement;
		const emailInput = form.elements.namedItem('email') as HTMLInputElement;
		const companyInput = form.elements.namedItem('company') as HTMLInputElement;
		const messageInput = form.elements.namedItem('message') as HTMLTextAreaElement;

		const showError = (message: string) => {
			errorText.textContent = message;
			errorBox.hidden = false;
			successBox.hidden = true;
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();

			const name = nameInput.value.trim();
			const email = emailInput.value.trim();
			const company = companyInput.value.trim();
			const message = messageInput.value.trim();
			const emailOk = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

			if (!name || !email || !message) {
				showError('Completa nombre, correo y mensaje.');
				return;
			}

			if (!emailOk) {
				showError('Ingresa un correo válido.');
				return;
			}

			errorBox.hidden = true;
			successBox.hidden = true;
			submitButton.disabled = true;
			submitButton.textContent = 'Enviando…';

			try {
				const recaptchaToken = await getRecaptchaToken();

				const response = await fetch('/api/contact', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify({ name, email, company, message, recaptchaToken }),
				});

				const result = (await response.json()) as { success: boolean; message?: string };

				if (!response.ok || !result.success) {
					showError(result.message ?? 'No pudimos enviar tu mensaje. Intenta de nuevo.');
					return;
				}

				successBox.hidden = false;
				form.reset();
			} catch {
				showError('No pudimos enviar tu mensaje. Revisa tu conexión e intenta de nuevo.');
			} finally {
				submitButton.disabled = false;
				submitButton.textContent = 'Enviar mensaje';
			}
		});
	}
</script>
